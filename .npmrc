# Configuración de seguridad para pnpm

# Las dependencias deben tener al menos 24 horas (1440 minutos) en el registro
# antes de poder ser instaladas. Esto protege contra ataques de typosquatting
# y paquetes maliciosos recién publicados.
minimum-release-age=1440

# No permite la ejecución de scripts arbitrarios durante la instalación.
# Muchos ataques de malware en paquetes npm ocurren en scripts 'preinstall' o 'postinstall'.
ignore-scripts=true

# Fuerza el uso de las versiones de Node y npm especificadas en package.json (engines).
engine-strict=true

# Asegura que siempre se realicen auditorías de seguridad al instalar paquetes.
audit=true

# Asegura que las conexiones al registro de npm sean siempre seguras (SSL).
strict-ssl=true

# Guarda la versión exacta de las dependencias en package.json para evitar cambios inesperados.
save-exact=true
